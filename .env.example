# ═══════════════════════════════════════════════════════════════
# Drone RID 生产环境变量
# 1. cp .env.example .env
# 2. 运行下面的命令生成随机密钥，填入 .env
# 3. 绝对不要把 .env 提交到 Git!
# ═══════════════════════════════════════════════════════════════

# ── 域名 ──
DOMAIN=drone.yourdomain.com

# ── 数据库密码 ──
# 生成: python3 -c "import secrets; print(secrets.token_hex(16))"
DB_PASSWORD=change-me

# ── JWT + Session 密钥 (各 64 字符 hex) ──
# 生成: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me
WEB_SECRET_KEY=change-me

# ── CORS 允许的来源 ──
# 多个用逗号分隔，或留 * 表示允许所有来源
CORS_ORIGINS=https://drone.yourdomain.com

# ── EMQX Dashboard 管理员密码 ──
EMQX_ADMIN_PASSWORD=change-me

# ── 默认管理员账户 (首次启动时自动创建) ──
ADMIN_USER=admin
ADMIN_PASS=change-me

# ── 设备预共享密钥 (JSON) ──
DEVICE_SECRETS={}

# ── SMS 短信网关 (告警通知专责人员) ──
# twilio (推荐, 国际短信, https://www.twilio.com)
# alibaba (阿里云短信, 需国内企业认证)
# simulated (模拟模式, 仅日志输出)
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+1234567890
# 阿里云备用 (仅 SMS_PROVIDER=alibaba 时需要)
# SMS_AK=your_aliyun_access_key
# SMS_SK=your_aliyun_access_secret
# SMS_SIGN_NAME=无人机监测
# SMS_TEMPLATE_CODE=SMS_XXXXXXXX
